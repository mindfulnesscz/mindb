# Copy to supabase/functions/.env for local edge function development.
# Same secrets as remote: supabase secrets set …

R2_BUCKET=your-bucket-name
R2_PUBLIC_DOMAIN=https://pub-xxxx.r2.dev

CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_PARENT_ACCESS_KEY_ID=your-r2-parent-access-key-id
